# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Django
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
DB_NAME=vilapay_dev
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Nomba API — Production (get from Nomba dashboard → Settings → API Keys)
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_WEBHOOK_SECRET=

# Nomba API — Sandbox/Test credentials (Nomba dashboard → Sandbox → API Keys)
# Note: development.py reads TEST_CLIENT_ID and TEST_PRIVATE_KEY (Nomba's key names)
TEST_CLIENT_ID=
TEST_PRIVATE_KEY=
NOMBA_ACCOUNT_ID=

# AWS (only needed in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
