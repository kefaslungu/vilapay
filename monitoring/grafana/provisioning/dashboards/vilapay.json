{
  "title": "Vilapay Overview",
  "uid": "vilapay-overview",
  "tags": ["vilapay"],
  "timezone": "Africa/Lagos",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Active Ajo Groups",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "vilapay_active_groups_total",
          "legendFormat": "Active Groups",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Payments Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "rate(vilapay_payment_success_total[5m]) / (rate(vilapay_payment_success_total[5m]) + rate(vilapay_payment_failure_total[5m])) * 100",
          "legendFormat": "Success %",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 98 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Tier Upgrades (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "increase(vilapay_tier_upgrades_total[24h])",
          "legendFormat": "Upgrades",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "Direct Debit Mandates (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "increase(vilapay_direct_debit_mandates_total[24h])",
          "legendFormat": "Mandates",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "Payment Volume (per method)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(vilapay_payment_success_total[5m])",
          "legendFormat": "{{payment_method}} / {{tier}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 6,
      "title": "Payout Duration (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(vilapay_payout_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vilapay_payout_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, rate(vilapay_payout_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "Webhook Processing Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(vilapay_webhook_processing_seconds_bucket[5m]))",
          "legendFormat": "p95 {{event_type}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "title": "Django HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(django_http_requests_total_by_method_total[5m])",
          "legendFormat": "{{method}}",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
